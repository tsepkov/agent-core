# Restate ingress URL — used server-side for dispatching and client-side for pubsub SSE.
RESTATE_INGRESS_URL=http://localhost:8080
NEXT_PUBLIC_RESTATE_INGRESS_URL=http://localhost:8080

# OpenRouter credentials for the LLM provider.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Any OpenRouter model slug. Default is a free Gemma model.
OPENROUTER_MODEL=google/gemma-3-27b-it:free

# Yandex Search API — required for the web_search tool.
# Create a service account, generate an API key and find your folder ID at console.yandex.cloud.
YC_API_KEY=
YC_FOLDER_ID=

# Mem0 long-term memory — optional. When set, the agent will remember important facts across sessions.
# Get a key at https://app.mem0.ai/dashboard/api-keys
MEM0_API_KEY=
